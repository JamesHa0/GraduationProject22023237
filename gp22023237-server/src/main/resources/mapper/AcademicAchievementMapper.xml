<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jameshao.gp22023237.mapper.AcademicAchievementMapper">

    <resultMap id="AcademicAchievementWithDetailsDTOMap" type="com.jameshao.gp22023237.DTO.AcademicAchievementWithDetailsDTO">
        <id property="id" column="id"/>
        <result property="studentId" column="student_id"/>
        <result property="studentNo" column="student_no"/>
        <result property="studentName" column="student_name"/>
        <result property="achievementType" column="achievement_type"/>
        <result property="title" column="title"/>
        <result property="authors" column="authors"/>
        <result property="publicationDate" column="publication_date"/>
        <result property="journalName" column="journal_name"/>
        <result property="journalLevel" column="journal_level"/>
        <result property="volume" column="volume"/>
        <result property="issue" column="issue"/>
        <result property="pages" column="pages"/>
        <result property="doi" column="doi"/>
        <result property="patentNo" column="patent_no"/>
        <result property="patentType" column="patent_type"/>
        <result property="patentStatus" column="patent_status"/>
        <result property="awardName" column="award_name"/>
        <result property="awardLevel" column="award_level"/>
        <result property="awardIssuer" column="award_issuer"/>
        <result property="projectName" column="project_name"/>
        <result property="projectRole" column="project_role"/>
        <result property="abstractContent" column="abstract_content"/>
        <result property="mentorStatus" column="mentor_status"/>
        <result property="mentorComment" column="mentor_comment"/>
        <result property="secretaryStatus" column="secretary_status"/>
        <result property="secretaryComment" column="secretary_comment"/>
        <result property="deanStatus" column="dean_status"/>
        <result property="deanComment" column="dean_comment"/>
        <result property="attachmentPath" column="attachment_path"/>
        <result property="submitTime" column="submit_time"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <select id="listWithDetails" resultMap="AcademicAchievementWithDetailsDTOMap">
        SELECT
            aa.*,
            s.student_no,
            s.student_name
        FROM academic_achievement aa
        LEFT JOIN student s ON aa.student_id = s.id
        <where>
            <if test="studentId != null">
                AND aa.student_id = #{studentId}
            </if>
            <if test="studentIds != null and studentIds.size() > 0">
                AND aa.student_id IN
                <foreach collection="studentIds" item="id" open="(" separator="," close=")">
                    #{id}
                </foreach>
            </if>
            <if test="achievementType != null">
                AND aa.achievement_type = #{achievementType}
            </if>
            <if test="status != null">
                <choose>
                    <when test="status == 1">
                        AND aa.mentor_status = 0
                    </when>
                    <when test="status == 2">
                        AND aa.secretary_status = 0
                    </when>
                    <when test="status == 3">
                        AND aa.dean_status = 0
                    </when>
                </choose>
            </if>
        </where>
        ORDER BY aa.submit_time DESC
    </select>

    <select id="getDetailWithDetails" resultMap="AcademicAchievementWithDetailsDTOMap">
        SELECT
            aa.*,
            s.student_no,
            s.student_name
        FROM academic_achievement aa
        LEFT JOIN student s ON aa.student_id = s.id
        WHERE aa.id = #{id}
    </select>

</mapper>
